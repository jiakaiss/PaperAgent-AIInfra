# Paper Agent Docker deployment environment
# Copy to .env and fill real values. Do NOT commit .env.

# Timezone used by containers and scheduler logs
TZ=Asia/Shanghai

# Public host port mapped to container port 8000
WEB_PORT=8000

# LLM API settings
# If scoring.api_key in config references ${ANTHROPIC_API_KEY}, set it here.
ANTHROPIC_API_KEY=
# Optional custom LLM gateway/proxy URL if your config references it.
ANTHROPIC_BASE_URL=

# Global SMTP settings for web subscriptions
# QQ mail example:
# SMTP_HOST=smtp.qq.com
# SMTP_PORT=587
SMTP_HOST=smtp.qq.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_SENDER=

# Optional webhook secrets if your config references them
FEISHU_WEBHOOK_ALICE=
WECOM_WEBHOOK=
DINGTALK_WEBHOOK=
DINGTALK_SECRET=
